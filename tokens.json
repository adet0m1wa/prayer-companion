      "ink": {
        "default": {
          "$type": "color",
          "$value": "#3D2E1F",
          "$description": "Base ink color — 100% opacity"
        },
        "muted": {
          "$type": "color",
          "$value": "#3D2E1FB3",
          "$description": "Ink at 70% opacity"
        },
        "faded": {
          "$type": "color",
          "$value": "#3D2E1F80",
          "$description": "Ink at 50% opacity"
        }
      },
      "accent": {
        "default": {
          "$type": "color",
          "$value": "#E63434",
          "$description": "Primary accent red — 100% opacity"
        },
        "subtle": {
          "$type": "color",
          "$value": "#E6343433",
          "$description": "Accent red at 20% opacity"
        }
      },
      "surface": {
