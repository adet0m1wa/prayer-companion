  "semantic": {
    "surface": {
      "default": {
        "$type": "color",
        "$value": "{color.surface.card}",
        "$description": "Primary surface — card backgrounds"
      },
      "canvas": {
        "$type": "color",
        "$value": "{color.surface.canvas}",
        "$description": "Page background"
      },
      "elevated": {
        "$type": "color",
        "$value": "{color.surface.card}",
        "$description": "Elevated card surfaces"
      },
      "muted": {
        "$type": "color",
        "$value": "{color.surface.muted}",
        "$description": "Disabled or secondary fills — chevron circles"
      },
      "overlay": {
        "$type": "color",
        "$value": "{color.surface.overlay}",
        "$description": "Semi-transparent overlay on verse card images"
      }
    },
    "text": {
      "primary": {
        "$type": "color",
        "$value": "{color.ink.default}",
        "$description": "Primary text color — headings, body, icons"
      },
      "secondary": {
        "$type": "color",
        "$value": "{color.ink.muted}",
        "$description": "Secondary text — metadata, subtitles"
      },
      "disabled": {
        "$type": "color",
        "$value": "{color.ink.faded}",
        "$description": "Disabled text and inactive tab labels"
      },
      "accent": {
        "$type": "color",
        "$value": "{color.accent.default}",
        "$description": "Accent-colored text — active tab labels, counters"
      }
    },
    "interactive": {
      "default": {
        "$type": "color",
        "$value": "{color.accent.default}",
        "$description": "Default interactive element color — active states, CTAs"
      },
      "subtle": {
        "$type": "color",
        "$value": "{color.accent.subtle}",
        "$description": "Subtle interactive borders — search bar focus ring"
      }
    },
    "icon": {
      "active": {
        "$type": "color",
        "$value": "{color.accent.default}",
        "$description": "Active icon color — selected tabs, tapped hearts, interactive elements"
      },
      "inactive": {
        "$type": "color",
        "$value": "{color.ink.faded}",
        "$description": "Inactive icon color — unselected tabs, disabled actions"
      }
    },
    "border": {
      "default": {
        "$type": "color",
        "$value": "{color.ink.faded}",
        "$description": "Default border color — dividers, separators"
      },
      "accent": {
        "$type": "color",
        "$value": "{color.accent.subtle}",
        "$description": "Accent border — search bar"
      }
    }
  },
  "typography": {
    "heading": {
      "display": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{font.family.display}",
          "fontSize": "22px",
          "fontWeight": "{font.weight.bold}",
          "fontStyle": "normal"
        },
        "$description": "Main page heading — 'Aspects of Love'"
      },
      "section": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{font.family.display}",
          "fontSize": "18px",
          "fontWeight": "{font.weight.semibold}",
          "fontStyle": "normal"
        },
        "$description": "Section headings — 'Explore Topics'"
      },
      "card": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{font.family.display}",
          "fontSize": "16px",
          "fontWeight": "{font.weight.semibold}",
          "fontStyle": "italic"
        },
        "$description": "Card title text — italic serif"
      },
      "toggle-active": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{font.family.display}",
          "fontSize": "16px",
          "fontWeight": "{font.weight.semibold}",
          "fontStyle": "normal"
        },
        "$description": "Active toggle tab label — Articles / Videos"
